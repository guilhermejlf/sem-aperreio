# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com

# Database (SQLite para dev, PostgreSQL para prod)
DB_NAME=db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# Redis (para Celery)
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=Sem Aperreio <noreply@semaperreio.app>

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:5173

# Task Trigger Secret (para cron-job.org chamar endpoint de tasks)
TASK_TRIGGER_SECRET=change-me-to-a-random-string

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com
